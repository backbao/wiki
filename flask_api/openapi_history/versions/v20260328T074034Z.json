{
  "components": {
    "schemas": {
      "ChatRequest": {
        "properties": {
          "is_stream": {
            "default": true,
            "description": "是否开启流式传输模式",
            "title": "Is Stream",
            "type": "boolean"
          },
          "message": {
            "description": "用户输入的聊天内容",
            "example": "你好",
            "title": "Message",
            "type": "string"
          },
          "model_id": {
            "default": "gpt-4",
            "description": "使用的模型ID",
            "title": "Model Id",
            "type": "string"
          }
        },
        "required": [
          "message"
        ],
        "title": "ChatRequest",
        "type": "object"
      },
      "ChatResponse": {
        "properties": {
          "reply": {
            "description": "AI 的回复内容",
            "title": "Reply",
            "type": "string"
          },
          "success": {
            "title": "Success",
            "type": "boolean"
          }
        },
        "required": [
          "success",
          "reply"
        ],
        "title": "ChatResponse",
        "type": "object"
      },
      "ImageRequest": {
        "properties": {
          "prompt": {
            "description": "画图的提示词",
            "example": "一只有翅膀的猫",
            "title": "Prompt",
            "type": "string"
          },
          "size": {
            "default": "1024x1024",
            "description": "图片分辨率",
            "title": "Size",
            "type": "string"
          }
        },
        "required": [
          "prompt"
        ],
        "title": "ImageRequest",
        "type": "object"
      },
      "ImageResponse": {
        "properties": {
          "image_url": {
            "description": "生成好的图片地址",
            "title": "Image Url",
            "type": "string"
          }
        },
        "required": [
          "image_url"
        ],
        "title": "ImageResponse",
        "type": "object"
      },
      "ValidationErrorModel": {
        "properties": {
          "ctx": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "An optional object which contains values required to render the error message.",
            "title": "Error context"
          },
          "input": {
            "description": "The input provided for validation.",
            "title": "Input"
          },
          "loc": {
            "description": "The error's location as a list.",
            "items": {},
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "description": "A human readable explanation of the error.",
            "title": "Message",
            "type": "string"
          },
          "type": {
            "description": "A computer-readable identifier of the error type.",
            "title": "Error Type",
            "type": "string"
          },
          "url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "description": "The URL to further information about the error.",
            "title": "URL"
          }
        },
        "required": [
          "type",
          "loc",
          "msg",
          "input"
        ],
        "title": "ValidationErrorModel",
        "type": "object"
      }
    },
    "securitySchemes": null
  },
  "info": {
    "title": "AI Chat API",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/chat/": {
      "post": {
        "operationId": "chat_chat__post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatResponse"
                }
              }
            },
            "description": "OK"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ValidationErrorModel"
                  },
                  "type": "array"
                }
              }
            },
            "description": "Unprocessable Entity"
          }
        },
        "summary": "发送聊天消息",
        "tags": [
          "ChatService"
        ]
      }
    },
    "/api/chat/end": {
      "get": {
        "operationId": "chat_end_chat_end_get",
        "responses": {
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ValidationErrorModel"
                  },
                  "type": "array"
                }
              }
            },
            "description": "Unprocessable Entity"
          }
        },
        "summary": "结束当前对话",
        "tags": [
          "ChatService"
        ]
      }
    },
    "/api/chat/history": {
      "get": {
        "operationId": "chat_get_history_history_get",
        "responses": {
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ValidationErrorModel"
                  },
                  "type": "array"
                }
              }
            },
            "description": "Unprocessable Entity"
          }
        },
        "summary": "获取聊天历史",
        "tags": [
          "ChatService"
        ]
      }
    },
    "/api/image/generate": {
      "post": {
        "operationId": "image_generate_image_generate_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImageRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageResponse"
                }
              }
            },
            "description": "OK"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ValidationErrorModel"
                  },
                  "type": "array"
                }
              }
            },
            "description": "Unprocessable Entity"
          }
        },
        "summary": "根据提示词生成图片",
        "tags": [
          "ImageService"
        ]
      }
    }
  },
  "tags": [
    {
      "description": "AI 聊天相关接口",
      "name": "ChatService"
    },
    {
      "description": "AI 绘图相关接口",
      "name": "ImageService"
    }
  ]
}
